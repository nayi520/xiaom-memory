# =============================================================================
# 小M (Memory) · 生产环境变量模板（ECS / 阿里云）
# =============================================================================
# 用法：在 ECS 项目根复制为 .env.production 并填入真实值。
#       cp deploy/.env.production.example .env.production && vi .env.production
# 该文件【不入库】（.gitignore 已忽略 .env*），由 pm2 经 ecosystem.config.cjs 注入进程。
#
# 占位说明：所有 <...> 为待填占位；带「(由 P0 开通后提供)」的需等阿里云资源到位。
# 部分变量（OSS_* / DIRECTMAIL_* / AUTH_*）对应正在并行开发、尚未接线的模块，
# 这里先按约定预留键名；最终键名以各 lib 模块（src/lib/storage、src/lib/auth、
# src/lib/asr）落地后为准，接线时对齐即可。
# =============================================================================

# ===== 站点 ==================================================================
# 规范站点 URL（绝对链接 / metadata / 邮件里的 magic link 回跳基址）。
NEXT_PUBLIC_SITE_URL=https://memory.nayitools.cn
# Node 运行环境（pm2 也会设；保留以防直接 node 启动）。
NODE_ENV=production

# ===== 数据库：RDS PostgreSQL 16 + pgvector（广州·同 VPC）====================
# 走内网私网地址（同 VPC，免公网、低延迟、更安全）。形如：
#   postgres://USER:PASSWORD@HOST:5432/DBNAME
# 内网通常无需 sslmode；如用公网地址则按 RDS 要求加 ?sslmode=require。
DATABASE_URL=postgres://<user>:<password>@<rds-内网地址>:5432/<dbname>   # (由 P0 开通后提供)
# 可选：Drizzle / node-postgres 连接池上限（2核4G + 自用，5–10 足够；勿超 RDS 最大连接数）
# DATABASE_POOL_MAX=10

# ===== DashScope（百炼）：LLM + 嵌入 共用一个 Key ============================
# LLM：qwen-plus（主力）/ qwen-max（升级）；嵌入：text-embedding-v4(dimensions=1536)
DASHSCOPE_API_KEY=<dashscope-api-key>                                    # (由 P0 开通后提供)
# 可选覆盖默认：
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MEMORY_QWEN_PLUS=qwen-plus
# MEMORY_QWEN_MAX=qwen-max
# MEMORY_EMBEDDING_MODEL=text-embedding-v4

# ===== OSS（音频存储 + Fun-ASR 取源）========================================
# RAM 子账号 AccessKey（最小权限，仅授权该 bucket 的读写）。
# 注意：地域用广州，内网 endpoint 走 VPC 免公网流量；签名播放/Fun-ASR 提交需公网可达 URL，
#       具体内/外网 endpoint 用法以 src/lib/storage 模块落地为准。
OSS_REGION=oss-cn-guangzhou                                              # 广州，与 ECS/RDS 同区
OSS_BUCKET=<bucket-name>                                                 # (现有 2 个之一或新建)
OSS_ACCESS_KEY_ID=<ram-access-key-id>                                    # (由 P0 开通后提供)
OSS_ACCESS_KEY_SECRET=<ram-access-key-secret>                            # (由 P0 开通后提供)
# 内网 endpoint（同 VPC 上传更快/免公网费）：
OSS_ENDPOINT=https://oss-cn-guangzhou-internal.aliyuncs.com
# 公网 endpoint（生成对外可访问/可被 Fun-ASR 拉取的 URL 时用；按模块实现取舍）：
# OSS_PUBLIC_ENDPOINT=https://oss-cn-guangzhou.aliyuncs.com

# ===== DirectMail（邮件发信：Auth.js magic link）============================
# 发信域名需先在 DirectMail 加 DNS 验证（约 20 分钟生效）。
DIRECTMAIL_ACCESS_KEY_ID=<ram-access-key-id>                            # 可复用上面的 RAM（或单独子账号）
DIRECTMAIL_ACCESS_KEY_SECRET=<ram-access-key-secret>
DIRECTMAIL_REGION=cn-hangzhou                                           # DirectMail 多在杭州地域，按控制台为准
DIRECTMAIL_ACCOUNT_NAME=<noreply@mail.nayitools.cn>                     # 已验证的发信地址
DIRECTMAIL_FROM_ALIAS=小M                                               # 发件人显示名（可选）

# ===== Auth.js（自研鉴权：magic link + Apple）===============================
# 会话加密密钥：openssl rand -base64 32  生成，务必随机且保密。
AUTH_SECRET=<openssl rand -base64 32>
# Auth.js v5 用 AUTH_URL 作为回调基址（= 站点 URL）。
AUTH_URL=https://memory.nayitools.cn
# Apple 登录（Service ID + 私钥签发的 client secret），P2 接 Apple 时填：
# AUTH_APPLE_ID=<apple-service-id>
# AUTH_APPLE_SECRET=<apple-client-secret-or-jwt>
# 注：以上 AUTH_* 键名以 src/lib/auth 模块落地为准，接线时对齐。

# ===== Cron（定时任务鉴权）==================================================
# 系统 crontab 调 /api/cron/{digest,remind} 时带的 Bearer。随机长字符串。
# 生成：openssl rand -hex 32
CRON_SECRET=<openssl rand -hex 32>

# ===== Web Push（复习提醒）==================================================
# 生成密钥对：npx web-push generate-vapid-keys
# 未配置时优雅降级：设置页按钮禁用、/api/cron/remind 返回 503。
VAPID_PUBLIC_KEY=<vapid-public-key>
VAPID_PRIVATE_KEY=<vapid-private-key>
VAPID_SUBJECT=mailto:admin@nayitools.cn

# ===== 过渡期遗留（迁移完成后删除）==========================================
# 以下为去 Supabase 过渡期变量。查询层尚未全切 Drizzle 前，部分 supabase.from()
# 仍在用，故生产暂时仍需 Supabase 段；P1 查询层切完后可整段删除。
# NEXT_PUBLIC_SUPABASE_URL=<supabase-url>
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# 语音转写在 Fun-ASR 接线前仍走 Whisper，则需：
# OPENAI_API_KEY=<openai-key>
# digest 流水线 LLM 若尚未切 Qwen 则仍读 Anthropic（现 llm.ts 已切，通常无需）：
# ANTHROPIC_API_KEY=<anthropic-key>
