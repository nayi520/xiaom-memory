# ===== Supabase =====
# 本地开发：supabase start 后终端会打印这三个值
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===== App =====
# 站点规范域名（用于 metadata / 绝对 URL）；部署后把 memory.nayitools.cn 解析到此服务
NEXT_PUBLIC_SITE_URL=https://memory.nayitools.cn

# ===== LLM =====
# Claude（阶段 2 AI 整理流水线用）
ANTHROPIC_API_KEY=sk-ant-...

# 可选：覆盖默认模型（默认 haiku=claude-3-5-haiku-latest，sonnet=claude-sonnet-4-5）
# MEMORY_CLAUDE_HAIKU=
# MEMORY_CLAUDE_SONNET=

# OpenAI（Whisper 语音转写 + embedding）
# 未配置时语音记录仍可保存，转写降级为"待配置"
OPENAI_API_KEY=sk-...

# ===== Cron =====
# 定时任务鉴权密钥（阶段 2/3 用），随机长字符串
CRON_SECRET=change-me

# ===== Web Push（阶段 3 复习提醒）=====
# 生成密钥对：npx web-push generate-vapid-keys
# 未配置时优雅降级：设置页按钮禁用并提示，/api/cron/remind 返回 503
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@nayitools.cn
